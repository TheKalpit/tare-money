{
	"name": "tare-money",
	"version": "0.1.0",
	"description": "A local-first money tracker.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"format:check": "prettier --check src/",
		"format:fix": "prettier --write src/",
		"prepare": "husky"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"pta",
		"plain-text-accounting",
		"finance",
		"money",
		"ledger"
	],
	"license": "MIT",
	"author": "Kalpit Jain",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TheKalpit/tare-money.git"
	},
	"bugs": {
		"url": "https://github.com/TheKalpit/tare-money/issues"
	},
	"homepage": "https://github.com/TheKalpit/tare-money",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"esbuild": "0.25.5",
		"esbuild-css-modules-plugin": "^3.1.5",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"husky": "^9.1.7",
		"jiti": "2.6.1",
		"lint-staged": "^16.4.0",
		"obsidian": "^1.8.0",
		"prettier": "^3.8.2",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.2"
	},
	"lint-staged": {
		"src/**/*.{ts,tsx}": [
			"prettier --write",
			"eslint --fix"
		],
		"src/**/*.css": [
			"prettier --write"
		]
	},
	"dependencies": {
		"downshift": "^9.3.2",
		"react": "^19.2.4",
		"react-datepicker": "^9.1.0",
		"react-dom": "^19.2.4"
	}
}
